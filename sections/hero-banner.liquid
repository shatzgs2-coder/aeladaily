<!-- Hero Banner Section -->
<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="hero-texture"></div>
    <div class="hero-content">
      <p class="hero-eyebrow"><span class="hero-eyebrow-line"></span> {{ section.settings.eyebrow | default: 'Natural Daily' }} <span class="hero-eyebrow-line"></span></p>
      <h1 class="hero-title">{{ section.settings.heading | default: 'Bring nature' }}<br><em>{{ section.settings.heading_italic | default: 'home.' }}</em></h1>
      <p class="hero-subtitle">{{ section.settings.subtext | default: 'Natural materials. Handcrafted with care.<br>Made for the rituals of everyday life.' }}</p>
      <div class="hero-actions">
        <a href="{{ section.settings.cta_primary_url | default: routes.all_products_collection_url }}" class="btn-primary btn-large">{{ section.settings.cta_primary_label | default: 'Shop the Collection' }}</a>
        <a href="{{ section.settings.cta_secondary_url | default: '/pages/our-story' }}" class="btn-ghost-light">{{ section.settings.cta_secondary_label | default: 'Our Story' }}</a>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
    <div class="hero-badge">
      <div class="hero-badge-circle">
        <svg viewBox="0 0 100 100" width="100%" height="100%">
          <defs><path id="circle-path" d="M50,50 m-38,0 a38,38 0 1,1 76,0 a38,38 0 1,1 -76,0"/></defs>
          <text font-size="9" font-family="Jost" letter-spacing="2" fill="#8B7355"><textPath href="#circle-path">NATURAL MATERIALS &bull; HANDCRAFTED &bull; PLASTIC FREE &bull; </textPath></text>
        </svg>
        <div class="hero-badge-center">&#10047;</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Natural Daily"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring nature"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading Italic Part",
      "default": "home."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Natural materials. Handcrafted with care. Made for the rituals of everyday life."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA Label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
