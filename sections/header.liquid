<!-- Header - Main navigation with logo, mega menu, icons, and mobile menu -->
<header class="site-header" id="site-header" data-header>
  <!-- Top utility bar -->
  <div class="header__utility">
    <div class="container header__utility-inner">
      <div class="header__utility-left">
        {%- for link in linklists[section.settings.utility_menu].links -%}
          <a href="{{ link.url }}" class="header__utility-link">{{ link.title }}</a>
        {%- endfor -%}
      </div>
      <div class="header__utility-right">
        <span class="header__locale">
          {{ request.locale.iso_code | upcase }} / EUR €
        </span>
      </div>
    </div>
  </div>

  <!-- Main header bar -->
  <div class="header__main">
    <div class="container header__main-inner">

      <!-- Mobile menu toggle -->
      <button
        class="header__menu-toggle"
        id="mobile-menu-toggle"
        aria-label="{{ 'general.accessibility.menu' | t | default: 'Menu' }}"
        aria-expanded="false"
        aria-controls="mobile-menu-drawer"
      >
        <span class="hamburger">
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
        </span>
      </button>

      <!-- Logo -->
      <div class="header__logo">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="header__logo-link">
            {{
              settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag:
                widths: '200, 300, 400, 500',
                alt: shop.name,
                class: 'header__logo-img'
            }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="header__logo-text">
            <span class="logo-text-main">AELA</span><span class="logo-text-accent">DAILY</span>
          </a>
        {%- endif -%}
      </div>

      <!-- Desktop Navigation -->
      <nav class="header__nav" id="main-nav" aria-label="Primary navigation">
        <ul class="header__nav-list">
          {%- for link in linklists[section.settings.main_menu].links -%}
            <li class="header__nav-item{% if link.links != empty %} has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">
                {{ link.title }}
                {%- if link.links != empty -%}
                  <svg width="10" height="6" viewBox="0 0 10 6" fill="none" class="header__nav-arrow"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.2"/></svg>
                {%- endif -%}
              </a>

              {%- if link.links != empty -%}
                <!-- Mega Menu Dropdown -->
                <div class="mega-menu" aria-hidden="true">
                  <div class="container mega-menu__inner">
                    {%- for childlink in link.links -%}
                      <div class="mega-menu__column">
                        <h4 class="mega-menu__heading">
                          <a href="{{ childlink.url }}">{{ childlink.title }}</a>
                        </h4>
                        {%- if childlink.links != empty -%}
                          <ul class="mega-menu__links">
                            {%- for grandchild in childlink.links -%}
                              <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- elsif childlink.type == 'collection_link' -%}
                          {%- assign col = childlink.object -%}
                          {%- if col.products_count > 0 -%}
                            <div class="mega-menu__preview">
                              {%- for product in col.products limit: 2 -%}
                                <a href="{{ product.url }}" class="mega-menu__product">
                                  {%- if product.featured_image != blank -%}
                                    {{ product.featured_image | image_url: width: 120 | image_tag: alt: product.title, loading: 'lazy' }}
                                  {%- endif -%}
                                  <span class="mega-menu__product-title">{{ product.title }}</span>
                                  <span class="mega-menu__product-price">{{ product.price | money }}</span>
                                </a>
                              {%- endfor -%}
                            </div>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                    {%- endfor -%}

                    <!-- Featured image / CTA area -->
                    {%- if section.settings.mega_menu_image != blank or section.settings.mega_menu_text != blank -%}
                      <div class="mega-menu__featured">
                        {%- if section.settings.mega_menu_image != blank -%}
                          <div class="mega-menu__featured-img">
                            {{
                              section.settings.mega_menu_image
                              | image_url: width: 400
                              | image_tag: alt: section.settings.mega_menu_image.alt, loading: 'lazy'
                            }}
                          </div>
                        {%- endif -%}
                        {%- if section.settings.mega_menu_text != blank -%}
                          <p class="mega-menu__featured-text">{{ section.settings.mega_menu_text }}</p>
                        {%- endif -%}
                        {%- if section.settings.mega_menu_cta != blank and section.settings.mega_menu_cta_url != blank -%}
                          <a href="{{ section.settings.mega_menu_cta_url }}" class="btn btn--small btn--outline">
                            {{ section.settings.mega_menu_cta }} &rarr;
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      <!-- Header Icons (Search / Account / Cart) -->
      <div class="header__actions">
        <button
          class="header__action-btn"
          id="search-toggle"
          aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
          data-action="toggle-search"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>

        <a href="{{ routes.account_url }}" class="header__action-btn" aria-label="{{ 'customer.account.title' | t | default: 'Account' }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        <button
          class="header__action-btn header__cart-btn"
          id="cart-toggle"
          aria-label="{{ 'sections.cart.title' | t | default: 'Cart' }}"
          data-action="toggle-cart"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Category navigation bar (below main nav) -->
  {%- if section.settings.show_category_nav -%}
  <div class="header__categories">
    <div class="container">
      <nav class="category-nav" aria-label="Category navigation">
        <ul class="category-nav__list">
          {%- for link in linklists[section.settings.category_menu].links limit: 8 -%}
            <li><a href="{{ link.url }}" class="category-nav__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>
  </div>
  {%- endif -%}
</header>

<!-- Mobile Menu Drawer -->
<div class="mobile-menu-drawer" id="mobile-menu-drawer" aria-hidden="true">
  <div class="mobile-menu-overlay" data-action="close-mobile-menu"></div>
  <div class="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="Navigation Menu">
    <div class="mobile-menu-header">
      <span class="mobile-menu-title">Menu</span>
      <button class="mobile-menu-close" data-action="close-mobile-menu" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="mobile-menu-content">
      <nav class="mobile-nav" aria-label="Mobile navigation">
        <ul class="mobile-nav__list">
          {%- for link in linklists[section.settings.main_menu].links -%}
            <li class="mobile-nav__item">
              <a href="{{ link.url }}" class="mobile-nav__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
              {%- if link.links != empty -%}
                <ul class="mobile-nav__sublist">
                  {%- for childlink in link.links -%}
                    <li><a href="{{ childlink.url }}">{{ childlink.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>

      <div class="mobile-menu-footer">
        <a href="{{ routes.account_url }}" class="mobile-menu-footer__link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 21v-2a4 4 0 00-4-4H9a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          My Account
        </a>
        <a href="{{ routes.search_url }}" class="mobile-menu-footer__link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Search
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* ===== HEADER GLOBAL ===== */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 900;
    background: var(--color-bg, #F5F1EA);
    border-bottom: 1px solid var(--color-border, #E8E0D5);
    transition: box-shadow 0.3s ease;
  }
  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(61,53,48,0.08);
  }

  /* Utility Bar */
  .header__utility {
    background: var(--color-text, #3D3530);
    color: var(--color-bg, #F5F1EA);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .header__utility-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 20px;
  }
  .header__utility-left {
    display: flex;
    gap: 20px;
  }
  .header__utility-link {
    color: rgba(245,241,234,0.7);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.04em;
    font-size: 11px;
  }
  .header__utility-link:hover { color: var(--color-bg); }
  .header__locale {
    font-size: 11px;
    opacity: 0.7;
  }

  /* Main Header */
  .header__main {
    padding: 14px 0;
  }
  .header__main-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  /* Mobile Toggle */
  .header__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }
  .hamburger__line {
    display: block;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Logo */
  .header__logo {
    flex-shrink: 0;
  }
  .header__logo-link {
    display: block;
    line-height: 0;
  }
  .header__logo-img {
    max-height: 42px;
    width: auto;
  }
  .header__logo-text {
    text-decoration: none;
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1;
  }
  .logo-text-main { color: var(--color-text); }
  .logo-text-accent { color: var(--color-primary, #8B7355); }

  /* Desktop Nav */
  .header__nav { flex: 1; display: flex; justify-content: center; }
  .header__nav-list {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .header__nav-item {
    position: relative;
  }
  .header__nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    padding: 8px 0;
    position: relative;
    transition: color 0.25s ease;
  }
  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-primary, #8B7355);
    transition: width 0.3s ease;
  }
  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: var(--color-primary, #8B7355);
  }
  .header__nav-link:hover::after,
  .header__nav-link.is-active::after {
    width: 100%;
  }
  .header__nav-arrow {
    transition: transform 0.25s ease;
    margin-top: 1px;
  }
  .header__nav-item:hover .header__nav-arrow {
    transform: rotate(180deg);
  }

  /* Mega Menu */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-white, #FFFFFF);
    box-shadow: 0 8px 40px rgba(61,53,48,0.12);
    padding: 36px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    pointer-events: none;
    border-top: 1px solid var(--color-border, #E8E0D5);
  }
  .header__nav-item:hover > .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  .mega-menu__inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 28px;
  }
  .mega-menu__column { min-width: 0; }
  .mega-menu__heading {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }
  .mega-menu__heading a {
    color: var(--color-text);
    text-decoration: none;
  }
  .mega-menu__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mega-menu__links li { margin-bottom: 8px; }
  .mega-menu__links a {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 14px;
    color: #66605A;
    text-decoration: none;
    transition: color 0.2s;
  }
  .mega-menu__links a:hover { color: var(--color-primary, #8B7355); }
  .mega-menu__preview { margin-top: 12px; }
  .mega-menu__product {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 10px;
  }
  .mega-menu__product img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 6px;
    background: var(--color-border, #E8E0D5);
  }
  .mega-menu__product-title {
    font-size: 13px;
    color: var(--color-text);
  }
  .mega-menu__product-price {
    font-size: 12px;
    color: #888;
  }
  .mega-menu__featured {
    background: var(--color-bg, #F5F1EA);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-width: 240px;
  }
  .mega-menu__featured-img {
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .mega-menu__featured-text {
    font-family: var(--font-script, 'Italianno', cursive);
    font-size: 22px;
    color: var(--color-primary, #8B7355);
    margin: 0 0 12px;
  }

  /* Action Buttons */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .header__action-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: var(--color-text);
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .header__action-btn:hover { color: var(--color-primary, #8B7355); }

  /* Cart Count Badge */
  .header__cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background: var(--color-primary, #8B7355);
    color: var(--color-white, #FFFFFF);
    font-size: 10px;
    font-weight: 600;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .header__cart-count:empty,
  .header__cart-count[data-count="0"] {
    display: none;
  }

  /* Category Nav */
  .header__categories {
    background: var(--color-white, #FFFFFF);
    border-top: 1px solid var(--color-border, #E8E0D5);
  }
  .category-nav__list {
    display: flex;
    justify-content: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 10px 0;
    overflow-x: auto;
  }
  .category-nav__link {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: #66605A;
    white-space: nowrap;
    transition: color 0.2s;
    padding: 4px 0;
  }
  .category-nav__link:hover,
  .category-nav__link.is-active {
    color: var(--color-primary, #8B7355);
  }

  /* ===== MOBILE MENU ===== */
  .mobile-menu-drawer {
    position: fixed;
    inset: 0;
    z-index: 2000;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .mobile-menu-drawer.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu-overlay {
    position: absolute;
    inset: 0;
    background: rgba(61,53,48,0.45);
    backdrop-filter: blur(4px);
  }
  .mobile-menu-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(360px, 85vw);
    background: var(--color-bg, #F5F1EA);
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
    box-shadow: -8px 0 40px rgba(0,0,0,0.15);
  }
  .mobile-menu-drawer.is-open .mobile-menu-panel {
    transform: translateX(0);
  }
  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-border, #E8E0D5);
  }
  .mobile-menu-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 22px;
    font-weight: 600;
  }
  .mobile-menu-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text);
  }
  .mobile-menu-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px;
  }
  .mobile-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mobile-nav__item {
    border-bottom: 1px solid var(--color-border, #E8E0D5);
  }
  .mobile-nav__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 16px 0;
  }
  .mobile-nav__sublist {
    list-style: none;
    margin: 0 0 0 16px;
    padding: 0 0 12px;
  }
  .mobile-nav__sublist a {
    display: block;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 14px;
    color: #66605A;
    text-decoration: none;
    padding: 8px 0;
  }
  .mobile-menu-footer {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--color-border, #E8E0D5);
    display: flex;
    gap: 24px;
  }
  .mobile-menu-footer__link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text);
    text-decoration: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 992px) {
    .header__utility { display: none; }
    .header__menu-toggle { display: flex; }
    .header__nav { display: none; }
    .header__logo-text { font-size: 24px; }
    .header__categories { display: none; }
    .header__actions { gap: 0; }
  }

  @media (max-width: 480px) {
    .header__main { padding: 10px 0; }
    .header__logo-img { max-height: 34px; }
    .header__logo-text { font-size: 22px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Sticky header on scroll
  const header = document.getElementById('site-header');
  if (header) {
    window.addEventListener('scroll', function() {
      header.classList.toggle('is-scrolled', window.scrollY > 60);
    }, { passive: true });
  }

  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileDrawer = document.getElementById('mobile-menu-drawer');
  if (mobileToggle && mobileDrawer) {
    function openMobileMenu() {
      mobileDrawer.classList.add('is-open');
      mobileDrawer.setAttribute('aria-hidden', 'false');
      mobileToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileMenu() {
      mobileDrawer.classList.remove('is-open');
      mobileDrawer.setAttribute('aria-hidden', 'true');
      mobileToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    mobileToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      openMobileMenu();
    });
    mobileDrawer.querySelectorAll('[data-action="close-mobile-menu"]').forEach(function(el) {
      el.addEventListener('click', closeMobileMenu);
    });
  }
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
