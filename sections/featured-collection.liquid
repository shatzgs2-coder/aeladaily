<!-- Featured Collection - Product grid with configurable collection -->
<div class="featured-collection section" data-animate>
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="section-heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_italic != blank -%}
          <em>{{ section.settings.heading_italic }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="section-desc">{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.settings.show_view_all and section.settings.collection != blank -%}
        <a href="{{ collections[section.settings.collection].url }}" class="view-all-link">View All &rarr;</a>
      {%- endif -%}
    </div>

    <!-- Product Grid -->
    <div class="product-grid">
      {%- if section.settings.collection != blank -%}
        {%- assign collection = collections[section.settings.collection] -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="product-card" data-product-handle="{{ product.handle }}">
            <a href="{{ product.url }}" class="product-card__link">
              <!-- Image -->
              <div class="product-card__image-wrapper">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 540
                    | image_tag:
                      loading: 'lazy',
                      widths: '270, 400, 540',
                      alt: product.title,
                      class: 'product-card__img'
                  }}
                {%- else -%}
                  <div class="product-card__placeholder">
                    <svg viewBox="0 0 240 300" fill="none" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
                      <rect width="240" height="300" fill="#EDE8E0"/>
                      <text x="120" y="150" text-anchor="middle" font-family="'Cormorant Garamond', serif" font-size="16" fill="#C4BDB3">No Image</text>
                    </svg>
                  </div>
                {%- endif -%}

                <!-- Badges -->
                <div class="product-badges">
                  {%- if product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}
                    <span class="badge badge--bestseller">Bestseller</span>
                  {%- elsif product.tags contains 'new' -%}
                    <span class="badge badge--new">New</span>
                  {%- elsif product.compare_at_price > product.price -%}
                    <span class="badge badge--sale">Sale</span>
                  {%- endif -%}
                </div>

                <!-- Hover Actions -->
                <div class="product-card__actions">
                  <button
                    class="quick-add-btn"
                    data-action="quick-view"
                    data-product-handle="{{ product.handle }}"
                    aria-label="Quick view {{ product.title }}"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    Quick View
                  </button>
                </div>
              </div>

              <!-- Info -->
              <div class="product-card__info">
                {%- if product.vendor != blank and section.settings.show_vendor -%}
                  <p class="product-vendor">{{ product.vendor }}</p>
                {%- endif -%}

                <h3 class="product-title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>

                <div class="product-price-row">
                  <span class="product-price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="product-compare-at">{{ product.compare_at_price | money }}</span>
                    <span class="product-save">
                      Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
                    </span>
                  {%- endif -%}
                </div>

                <!-- Rating placeholder (can integrate with reviews app) -->
                {%- if section.settings.show_rating -%}
                  <div class="product-rating">
                    <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                    <span class="rating-count">(42)</span>
                  </div>
                {%- endif -%}
              </div>
            </a>

            <!-- Quick Add to Cart Button (below card) -->
            {%- if product.available -%}
              <button
                class="add-to-cart-btn"
                data-action="add-to-cart"
                data-variant-id="{{ product.variants.first.id }}"
                data-product-title="{{ product.title | escape }}"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                Add to Cart
              </button>
            {%- else -%}
              <button class="add-to-cart-btn add-to-cart-btn--soldout" disabled>Sold Out</button>
            {%- endif -%}
          </div>
        {%- endfor -%}

      {%- else -%}
        <!-- Placeholder products when no collection is selected -->
        {%- for i in (1..section.settings.products_to_show) -%}
          <div class="product-card product-card--skeleton">
            <div class="product-card__image-wrapper">
              <div class="product-card__placeholder">
                <svg viewBox="0 0 240 300" fill="none" width="100%" height="100%">
                  <rect width="240" height="300" fill="#EDE8E0"/>
                  <text x="120" y="155" text-anchor="middle" font-family="'Italianno', cursive" font-size="28" fill="#B8B0A5">Product {{ i }}</text>
                </svg>
              </div>
            </div>
            <div class="product-card__info">
              <p class="product-title skeleton-text"></p>
              <p class="skeleton-text skeleton-text--short"></p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .featured-collection { padding: 80px 0; }
  .section-header {
    text-align: center;
    margin-bottom: 48px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary, #8B7355);
    margin-bottom: 10px;
  }
  .section-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 500;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0 0 14px;
  }
  .section-heading em {
    font-style: italic;
    font-family: var(--font-script, 'Italianno', cursive);
    display: block;
    font-weight: 400;
    color: var(--color-primary, #8B7355);
    font-size: 1.15em;
  }
  .section-desc {
    font-size: 15px;
    line-height: 1.7;
    color: #66605A;
    margin: 0 auto 20px;
  }
  .view-all-link {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary, #8B7355);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s;
    display: inline-block;
    padding-bottom: 2px;
  }
  .view-all-link:hover { border-color: var(--color-primary, #8B7355); }

  /* Product Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  /* Product Card */
  .product-card {
    display: flex;
    flex-direction: column;
  }
  .product-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: #EDE8E0;
    aspect-ratio: 4 / 5;
    margin-bottom: 14px;
  }
  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
  }
  .product-card:hover .product-card__img {
    transform: scale(1.04);
  }
  .product-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Badges */
  .product-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .badge--bestseller { background: var(--color-primary, #8B7355); color: #fff; }
  .badge--new { background: var(--color-accent, #A8B5A0); color: #fff; }
  .badge--sale { background: #C45C4A; color: #fff; }

  /* Card Hover Actions */
  .product-card__actions {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
    background: linear-gradient(transparent, rgba(61,53,48,0.75));
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s ease;
  }
  .product-card:hover .product-card__actions {
    opacity: 1;
    transform: translateY(0);
  }
  .quick-add-btn {
    background: var(--color-white, #FFFFFF);
    border: none;
    border-radius: 8px;
    padding: 10px 18px;
    cursor: pointer;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s ease;
    width: 100%;
    justify-content: center;
  }
  .quick-add-btn:hover {
    background: var(--color-primary, #8B7355);
    color: #fff;
  }

  /* Info */
  .product-card__info { padding: 0 4px; }
  .product-vendor {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin: 0 0 4px;
  }
  .product-title {
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0 0 8px;
  }
  .product-title a {
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.2s;
  }
  .product-title a:hover { color: var(--color-primary, #8B7355); }
  .product-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }
  .product-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
  }
  .product-compare-at {
    font-size: 13px;
    color: #AAA;
    text-decoration: line-through;
  }
  .product-save {
    font-size: 11px;
    color: #C45C4A;
    font-weight: 500;
  }
  .product-rating {
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .stars { color: #D4A853; font-size: 12px; letter-spacing: -1px; }
  .rating-count { font-size: 11px; color: #AAA; }

  /* Add to Cart Button */
  .add-to-cart-btn {
    margin-top: auto;
    padding: 11px 20px;
    border: 1px solid var(--color-border, #E8E0D5);
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    font-family: var(--font-body, 'Jost', sans-serif);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: all 0.25s ease;
  }
  .add-to-cart-btn:hover {
    background: var(--color-text, #3D3530);
    color: var(--color-bg, #F5F1EA);
    border-color: var(--color-text, #3D3530);
  }
  .add-to-cart-btn--soldout {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Skeleton */
  .skeleton-text {
    height: 16px;
    background: linear-gradient(90deg, #EDE8E0 25%, #E8E0D5 50%, #EDE8E0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }
  .skeleton-text--short { width: 60%; }
  @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

  /* Responsive */
  @media (max-width: 992px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); gap: 22px; }
    .featured-collection { padding: 60px 0; }
  }
  @media (max-width: 768px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .featured-collection { padding: 48px 0; }
  }
  @media (max-width: 480px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Customer Favorites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Italic subheading",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": ""
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor name",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating stars",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "heading": "Bestsellers"
      }
    }
  ]
}
{% endschema %}
