<!-- Featured Collection Section -->
<section class="section section-bestsellers" id="featured-collection">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.collection != blank -%}
        <a href="{{ collections[section.settings.collection].url }}" class="section-view-all">View all &rarr;</a>
      {%- endif -%}
    </div>
    <div class="product-grid">
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- if featured_collection != blank -%}
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          <div class="product-card">
            <a href="{{ product.url }}" class="product-card-link">
              <div class="product-img">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 480 | image_tag: class: 'product-photo', alt: product.title, loading: 'lazy' }}
                {%- else -%}
                  <div class="product-img-placeholder">
                    <svg viewBox="0 0 240 240" width="100%" height="100%"><rect width="240" height="240" fill="#F5F1EA"/><text x="120" y="125" text-anchor="middle" font-family="Cormorant Garamond" font-size="14" fill="#8B7355" font-style="italic">{{ product.title }}</text></svg>
                  </div>
                {%- endif -%}
                {%- if product.tags contains 'bestseller' -%}
                  <span class="product-tag tag-bestseller">Bestseller</span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="product-tag tag-new">New</span>
                {%- endif -%}
                <div class="quick-add" onclick="event.preventDefault(); openQuickView('{{ product.handle }}')">Quick View +</div>
              </div>
              <div class="product-info">
                <p class="product-name">{{ product.title }}</p>
                <p class="product-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="price-sale">{{ product.price | money }}</span>
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </p>
              </div>
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card product-card-placeholder">
            <div class="product-img">
              <svg viewBox="0 0 240 300" width="100%" height="100%"><rect width="240" height="300" fill="#F5F1EA"/><text x="120" y="155" text-anchor="middle" font-family="Cormorant Garamond" font-size="12" fill="#C4B59A" font-style="italic">Add a collection</text></svg>
            </div>
            <div class="product-info">
              <p class="product-name">Product Name</p>
              <p class="product-price">&euro;00.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Customer Favorites"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4,
      "label": "Products to Show"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
