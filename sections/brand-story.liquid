<!-- Brand Story Feature Section -->
<section class="section section-story-feature" id="story">
  <div class="story-split">
    <div class="story-image-wrap">
      <div class="story-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 600 | image_tag: class: 'story-photo', alt: section.settings.heading, loading: 'lazy' }}
        {%- else -%}
          <svg viewBox="0 0 480 560" width="100%" height="100%">
            <rect width="480" height="560" fill="#E8E0D5"/>
            <text x="240" y="290" text-anchor="middle" font-family="Cormorant Garamond" font-size="16" fill="#8B7355" font-style="italic">handcrafted</text>
            <text x="240" y="310" text-anchor="middle" font-family="Jost" font-size="9" fill="#8B7355" letter-spacing="3">WITH CARE</text>
          </svg>
        {%- endif -%}
      </div>
      <div class="story-image-badge">
        <span class="story-badge-num">{{ section.settings.badge_number | default: '100%' }}</span>
        <span class="story-badge-text">{{ section.settings.badge_text | default: 'Natural Materials' | newline_to_br }}</span>
      </div>
    </div>
    <div class="story-text">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Our Story' }}</span>
      <h2 class="section-title story-title">{{ section.settings.heading | default: 'We believe the objects we live with should be honest, natural, and made to last.' }}</h2>
      <div class="story-body">
        {{ section.settings.body | default: '<p>AELADAILY was born from a simple conviction: that nourishment isn\'t a luxury reserved for special occasions. It\'s a daily practice.</p>' }}
      </div>
      <div class="story-values">
        {%- for block in section.blocks -%}
          <div class="story-value" {{ block.shopify_attributes }}>
            <span class="story-value-icon">{{ block.settings.icon }}</span>
            <span class="story-value-text">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
      <a href="{{ section.settings.cta_url | default: '/pages/our-story' }}" class="btn-secondary">{{ section.settings.cta_label | default: 'Read Our Story' }} &rarr;</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story Feature",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Badge Number",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Natural\nMaterials"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We believe the objects we live with should be honest, natural, and made to last."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Brand Value",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)",
          "default": "🌿"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Natural"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Story Feature",
      "blocks": [
        { "type": "value", "settings": { "icon": "🌿", "label": "Natural" } },
        { "type": "value", "settings": { "icon": "✋", "label": "Artisanal" } },
        { "type": "value", "settings": { "icon": "🤍", "label": "Mindful" } }
      ]
    }
  ]
}
{% endschema %}
