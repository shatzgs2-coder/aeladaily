<!-- Cart Drawer - Slide-out shopping cart overlay -->
<div class="cart-drawer" id="cart-drawer" aria-hidden="true">
  <div class="cart-drawer-overlay" data-action="close-cart"></div>
  <div class="cart-drawer-panel" role="dialog" aria-modal="true" aria-label="Shopping cart">
    <!-- Header -->
    <div class="cart-drawer-header">
      <h2>Shopping Cart (<span data-cart-count>{{ cart.item_count }}</span>)</h2>
      <button class="cart-drawer-close" data-action="close-cart" aria-label="Close cart">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Free shipping progress -->
    {%- assign free_threshold = 4900 -%}
    {%- assign remaining = free_threshold | minus: cart.total_price -%}
    <div class="cart-progress-bar" id="cart-progress-bar"{% if remaining <= 0 %} style="--progress:100%"{% endif %}>
      <div class="cart-progress-text">
        {%- if remaining <= 0 -%}
          &#9989; You qualify for free EU shipping!
        {%- else -%}
          Add {{ remaining | money }} more for <strong>free EU shipping</strong> &rarr;
        {%- endif -%}
      </div>
      <div class="cart-progress-track"><div class="cart-progress-fill" style="width:{% if cart.total_price >= free_threshold %}100{% else %}{{ cart.total_price | times: 100 | divided_by: free_threshold }}{% endif %}%"></div></div>
    </div>

    <!-- Cart Items -->
    <div class="cart-drawer-items" id="cart-drawer-items">
      {%- if cart.items.size > 0 -%}
        {%- for item in cart.items -%}
          <div class="drawer-item" data-line-key="{{ item.key }}">
            <a href="{{ item.url }}" class="drawer-item-img-link">
              {%- if item.image != blank -%}
                {{ item.image | image_url: width: 100 | image_tag: alt: item.title, loading: 'lazy', class: 'drawer-item-img' }}
              {%- else -%}
                <div class="drawer-item-placeholder"></div>
              {%- endif -%}
            </a>
            <div class="drawer-item-info">
              <h4><a href="{{ item.url }}">{{ item.product.title | truncatewords: 4 }}</a></h4>
              {%- unless item.product.has_only_default_variant -%}<span class="drawer-variant">{{ item.variant.title }}</span>{%- endunless -%}

              <div class="drawer-item-bottom">
                <div class="drawer-qty-controls">
                  <button type="button" class="qty-btn qty-sm" data-action="update-cart-qty" data-line-key="{{ item.key }}" data-new-qty="{{ item.quantity | minus: 1 }}">&minus;</button>
                  <span class="drawer-qty-val">{{ item.quantity }}</span>
                  <button type="button" class="qty-btn qty-sm" data-action="update-cart-qty" data-line-key="{{ item.key }}" data-new-qty="{{ item.quantity | plus: 1 }}">&plus;</button>
                </div>
                <div class="drawer-item-price">{{ item.final_line_price | money }}</div>
                <button type="button" class="drawer-remove" data-action="remove-cart-item" data-line-key="{{ item.key }}" aria-label="Remove">&times;</button>
              </div>
            </div>
          </div>
        {%- endfor -%}

      {%- else -%}
        <div class="cart-empty-state">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#CCC" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <p>Your cart is empty</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--sm">Shop Now</a>
        </div>
      {%- endif -%}
    </div>

    <!-- Footer (total + checkout) -->
    {%- if cart.items.size > 0 -%}
    <div class="cart-drawer-footer">
      <form action="/checkout" method="post">
        <div class="drawer-total-row">
          <span>Subtotal</span>
          <strong id="drawer-total-price">{{ cart.total_price | money }}</strong>
        </div>
        <p class="drawer-tax-note">Shipping and taxes calculated at checkout.</p>
        <button type="submit" name="checkout" class="btn btn--primary btn--lg btn--fullwidth drawer-checkout-btn">Checkout — {{ cart.total_price | money }}</button>
        <a href="{{ routes.cart_url }}" class="view-cart-link">View full cart &rarr;</a>
      </form>
    </div>
    {%- endif -%}
  </div>
</div>

<style>
  .cart-drawer{position:fixed;inset:0;z-index:3000;pointer-events:none;opacity:0;visibility:hidden;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);}
  .cart-drawer.is-open{pointer-events:auto;opacity:1;visibility:visible;}
  .cart-drawer-overlay{position:absolute;inset:0;background:rgba(61,53,48,0.45);backdrop-filter:blur(4px);}
  .cart-drawer-panel{position:absolute;top:0;right:0;bottom:0;width:min(420px,88vw);background:#fff;display:flex;flex-direction:column;transform:translateX(100%);transition:transform 0.35s cubic-bezier(0.4,0,0.2,1);box-shadow:-8px 0 40px rgba(0,0,0,0.15);}
  .cart-drawer.is-open .cart-drawer-panel{transform:translateX(0);}

  .cart-drawer-header{display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid #F0EBE3;}
  .cart-drawer-header h2{font-family:var(--font-heading,serif);font-size:18px;font-weight:600;margin:0;}
  .cart-drawer-close{background:none;border:none;cursor:pointer;padding:4px;color:#999;}

  /* Progress bar */
  .cart-progress-bar{padding:16px 24px;border-bottom:1px solid #F5F0EA;background:#FAF8F5;}
  .cart-progress-text{font-size:12px;color:#777;margin-bottom:8px;line-height:1.45;}
  .cart-progress-track{height:4px;border-radius:2px;background:#E8E0D5;}
  .cart-progress-fill{height:100%;border-radius:2px;background:var(--color-accent,#A8B5A0);transition:width 0.4s ease;}

  /* Items */
  .cart-drawer-items{flex:1;overflow-y:auto;padding:8px 24px;}
  .drawer-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid #F5F0EA;}
  .drawer-item-img-link{display:block;flex-shrink:0;width:72px;height:88px;border-radius:8px;overflow:hidden;background:#EDE8E0;}
  .drawer-item-img{width:100%;height:100%;object-fit:cover;}
  .drawer-item-placeholder{width:72px;height:88px;background:#EDE8E0;border-radius:8px;}
  .drawer-item-info{flex:1;min-width:0;}
  .drawer-item-info h4{font-size:13px;font-weight:500;margin:0 0 3px;line-height:1.35;}
  .drawer-item-info h4 a{color:#333;text-decoration:none;}
  .drawer-variant{font-size:11px;color:#999;}

  .drawer-item-bottom{display:flex;align-items:center;gap:10px;margin-top:8px;}
  .drawer-qty-controls{display:inline-flex;align-items:center;border:1px solid #EEE;border-radius:6px;}
  .qty-sm{width:28px;height:28px;border:none;background:#FAFAFA;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;color:#666;border-radius:4px;}
  .drawer-qty-val{font-size:13px;font-weight:500;width:22px;text-align:center;}

  .drawer-item-price{margin-left:auto;font-weight:600;font-size:13px;}
  .drawer-remove{width:26px;height:26px;border:none;background:none;cursor:pointer;font-size:18px;color:#DDD;}
  .drawer-remove:hover{color:#C45C4A;}

  .cart-empty-state{text-align:center;padding:48px 20px;color:#999;}
  .cart-empty-state svg{opacity:0.4;margin-bottom:12px;}
  .cart-empty-state p{margin:0 0 16px;font-size:15px;}

  /* Footer */
  .cart-drawer-footer{padding:20px 24px;border-top:1px solid #F0EBE3;background:#FAF8F5;}
  .drawer-total-row{display:flex;justify-content:space-between;font-size:16px;padding-bottom:10px;margin-bottom:4px;}
  .drawer-tax-note{font-size:11px;color:#AAA;margin-bottom:14px;}
  .drawer-checkout-btn{margin-bottom:10px;}
  .view-cart-link{display:block;text-align:center;font-size:13px;color:var(--color-primary);text-decoration:none;}
</style>
