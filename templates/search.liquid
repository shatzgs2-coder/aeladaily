<!-- Search Template -->
<div class="page-search container" style="padding: 60px 0; min-height: 60vh;">
  <h1 style="font-family: var(--font-heading); font-size: 32px; margin-bottom: 32px;">Search</h1>

  <form action="{{ routes.search_url }}" method="get" style="margin-bottom: 48px;">
    <input type="hidden" name="type" value="product">
    <div style="display: flex; gap: 12px; max-width: 560px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..."
        style="flex: 1; padding: 12px 18px; border: 1px solid var(--sand); font-family: var(--font-body); font-size: 14px;">
      <button type="submit" class="btn-primary">Search</button>
    </div>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p>No results found for "{{ search.terms }}".</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn-secondary" style="margin-top: 20px; display: inline-block;">Browse All Products</a>
    {%- else -%}
      <p style="margin-bottom: 24px;">{{ search.results_count }} results for "{{ search.terms }}"</p>
      <div class="product-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <div class="product-card">
              <a href="{{ item.url }}" class="product-card-link">
                <div class="product-img">
                  {%- if item.featured_image != blank -%}
                    {{ item.featured_image | image_url: width: 480 | image_tag: class: 'product-photo', alt: item.title, loading: 'lazy' }}
                  {%- else -%}
                    <div class="product-img-placeholder"><svg viewBox="0 0 240 300" width="100%" height="100%"><rect width="240" height="300" fill="#F5F1EA"/></svg></div>
                  {%- endif -%}
                </div>
                <div class="product-info">
                  <p class="product-name">{{ item.title }}</p>
                  <p class="product-price">{{ item.price | money }}</p>
                </div>
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div>
