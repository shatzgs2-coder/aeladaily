<!-- Search Template - Search results page -->
<div class="search-page section">
  <div class="container">
    <h1 style="font-family: var(--font-heading, serif); font-size: clamp(28px, 3.5vw, 38px); margin-bottom: 8px;">
      {%- if search.performed -%}
        {{ search.results_count }} results for "{{ search.terms | escape }}"
      {%- else -%}
        Search
      {%- endif -%}
    </h1>

    <!-- Search form (repeated at top for convenience) -->
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form-top" style="margin-bottom: 36px; max-width: 560px;">
      <input type="hidden" name="type" value="product">
      <input type="hidden" name="options[prefix]" value="last">
      <div style="display: flex; border: 2px solid var(--color-border, #E8E0D5); border-radius: 12px; overflow: hidden;">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products, collections..." style="flex:1;padding:14px 18px;border:none;font-family:var(--font-body,'Jost',sans-serif);font-size:14px;outline:none;background:transparent;">
        <button type="submit" style="padding:14px 24px;border:none;background:var(--color-text);color:#fff;cursor:pointer;font-family:var(--font-body);font-size:13px;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;transition:background 0.2s;">Search</button>
      </div>
    </form>

    {%- if search.performed -%}

      {%- if search.results_count == 0 -%}
        <div class="no-results" style="text-align:center;padding:60px 20px;">
          <p style="font-family: var(--font-heading,serif); font-size:22px;color:#999;margin-bottom:10px;">No results found</p>
          <p style="color:#BBB;font-size:14px;margin-bottom:20px;">Try different keywords or browse our collections.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">Browse All Products</a>
        </div>

      {%- else -%}

        <p style="font-size:13px;color:#999;margin-bottom:24px;">{{ search.results_count }} result(s) found</p>
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <div class="product-card">
                <a href="{{ item.url }}" class="product-card__link">
                  <div class="product-card__image-wrapper">
                    {%- if item.featured_image != blank -%}
                      {{ item.featured_image | image_url: width: 480 | image_tag: alt: item.title, loading: 'lazy', class: 'product-card__img' }}
                    {%- else -%}
                      <div class="product-card__placeholder"><svg viewBox="0 0 240 300" width="100%" height="100%"><rect width="240" height="300" fill="#EDE8E0"/></svg></div>
                    {%- endif -%}
                  </div>
                  <div class="product-card__info">
                    <h3 class="product-title"><a href="{{ item.url }}">{{ item.title }}</a></h3>
                    <span class="product-price">{{ item.price | money }}</span>
                  </div>
                </a>
                <button class="add-to-cart-btn" data-action="add-to-cart" data-variant-id="{{ item.variants.first.id }}" data-product-title="{{ item.title | escape }}">Add to Cart</button>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if search.results_count > 12 -%}
          <div class="pagination" style="display:flex;justify-content:center;padding:36px 0;">
            <nav aria-label="Search pagination">
              {%- if search.next -%}
                <a href="{{ search.next.url }}" class="btn btn--outline">Load More Results &rarr;</a>
              {%- endif -%}
            </nav>
          </div>
        {%- endif -%}

      {%- endif -%}

    {%- else -%}
      <!-- No search performed yet - show popular products or categories -->
      <div style="text-align:center;padding:40px 20px;">
        <p style="color:#999;font-size:16px;margin-bottom:24px;">What are you looking for today?</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;max-width:600px;margin:0 auto;">
          <a href="/search?q=ceramic&type=product" class="search-suggestion-btn">Ceramics</a>
          <a href="/search?q=macrame&type=product" class="search-suggestion-btn">Macramé</a>
          <a href="/search?q=cork&type=product" class="search-suggestion-btn">Cork</a>
          <a href="/search?q=wooden&type=product" class="search-suggestion-btn">Wooden Decor</a>
          <a href="/search?q=candles&type=product" class="search-suggestion-btn">Candles</a>
          <a href="/collections/all" class="search-suggestion-btn">View All</a>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .search-suggestion-btn {
    display:inline-block;padding:9px 20px;border:1.5px solid var(--color-border);border-radius:20px;
    font-size:13px;color:#777;text-decoration:none;transition:all 0.2s;
  }
  .search-suggestion-btn:hover{border-color:var(--color-primary);color:var(--color-primary);}
</style>
