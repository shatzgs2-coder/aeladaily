<!-- Collection Template -->
<div class="page-collection">
  <div class="collection-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="breadcrumb-sep">/</span>
        <span>{{ collection.title | default: 'All Products' }}</span>
      </nav>
      <h1 class="collection-title">{{ collection.title | default: 'All Products' }}</h1>
      {%- if collection.description != blank -%}
        <p class="collection-desc">{{ collection.description }}</p>
      {%- endif -%}
      <p class="collection-count">{{ collection.products_count }} products</p>
    </div>
  </div>

  <div class="container">
    <div class="collection-layout">
      <!-- Filter Sidebar -->
      <aside class="filter-sidebar" id="filterSidebar">
        <h3 class="filter-title">Filter</h3>

        {%- for filter in collection.filters -%}
          <div class="filter-group">
            <h4 class="filter-group-title">{{ filter.label }}</h4>
            {%- for value in filter.values -%}
              <label class="filter-option">
                <input type="checkbox"
                  name="{{ value.param_name }}"
                  value="{{ value.value }}"
                  {% if value.active %}checked{% endif %}
                  onchange="this.form.submit()">
                {{ value.label }}
                <span class="filter-count">({{ value.count }})</span>
              </label>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="filter-group">
            <h4 class="filter-group-title">Categories</h4>
            {%- for collection_item in collections -%}
              {%- unless collection_item.handle == 'frontpage' -%}
                <label class="filter-option">
                  <a href="{{ collection_item.url }}" class="{% if collection.handle == collection_item.handle %}active{% endif %}">
                    {{ collection_item.title }}
                  </a>
                </label>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}

        <!-- Price filter -->
        <div class="filter-group">
          <h4 class="filter-group-title">Price Range</h4>
          <label class="filter-option"><a href="?price=0-25">Under &euro;25</a></label>
          <label class="filter-option"><a href="?price=25-50">&euro;25 &ndash; &euro;50</a></label>
          <label class="filter-option"><a href="?price=50-100">&euro;50 &ndash; &euro;100</a></label>
          <label class="filter-option"><a href="?price=100+">Over &euro;100</a></label>
        </div>
      </aside>

      <!-- Product Grid -->
      <div class="collection-main">
        <div class="collection-toolbar">
          <button class="filter-toggle" onclick="document.getElementById('filterSidebar').classList.toggle('open')">
            Filter <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/></svg>
          </button>
          <p class="results-count">{{ collection.products_count }} results</p>
          <div class="sort-wrap">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <select class="sort-select" name="sort_by" onchange="window.location.search = '?sort_by=' + this.value">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
          </div>
        </div>

        {%- paginate collection.products by 12 -%}
          <div class="product-grid" id="collectionGrid">
            {%- for product in collection.products -%}
              <div class="product-card">
                <a href="{{ product.url }}" class="product-card-link">
                  <div class="product-img">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 480 | image_tag: class: 'product-photo', alt: product.title, loading: 'lazy' }}
                    {%- else -%}
                      <div class="product-img-placeholder">
                        <svg viewBox="0 0 240 300" width="100%" height="100%"><rect width="240" height="300" fill="#F5F1EA"/><text x="120" y="155" text-anchor="middle" font-family="Cormorant Garamond" font-size="12" fill="#8B7355" font-style="italic">{{ product.title }}</text></svg>
                      </div>
                    {%- endif -%}
                    {%- if product.tags contains 'bestseller' -%}
                      <span class="product-tag tag-bestseller">Bestseller</span>
                    {%- elsif product.tags contains 'new' -%}
                      <span class="product-tag tag-new">New</span>
                    {%- elsif product.compare_at_price > product.price -%}
                      <span class="product-tag tag-sale">Sale</span>
                    {%- endif -%}
                    <div class="quick-add" onclick="event.preventDefault(); openQuickView('{{ product.handle }}')">Quick View +</div>
                  </div>
                  <div class="product-info">
                    <p class="product-name">{{ product.title }}</p>
                    <p class="product-price">
                      {%- if product.compare_at_price > product.price -%}
                        <span class="price-sale">{{ product.price | money }}</span>
                        <span class="price-compare">{{ product.compare_at_price | money }}</span>
                      {%- else -%}
                        {{ product.price | money }}
                      {%- endif -%}
                    </p>
                  </div>
                </a>
              </div>
            {%- else -%}
              <div class="collection-empty">
                <p>No products found in this collection.</p>
                <a href="{{ routes.all_products_collection_url }}" class="btn-secondary">View All Products</a>
              </div>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="pagination">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</div>
