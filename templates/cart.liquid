<!-- Cart Template -->
<div class="page-cart container" style="padding: 60px 0; min-height: 60vh;">
  <h1 style="font-family: var(--font-heading); font-size: 32px; margin-bottom: 40px;">Your Cart</h1>

  {%- if cart.item_count > 0 -%}
    {% form 'cart', cart %}
      <div style="display: grid; grid-template-columns: 1fr 360px; gap: 40px;">
        <div class="cart-items-list">
          {%- for item in cart.items -%}
            <div class="cart-item" style="display: flex; gap: 20px; padding: 20px 0; border-bottom: 1px solid var(--cream);">
              <div style="width: 100px; flex-shrink: 0;">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 200 | image_tag: alt: item.title, style: 'width: 100%; border-radius: 4px;' }}
                {%- endif -%}
              </div>
              <div style="flex: 1;">
                <p style="font-family: var(--font-heading); font-size: 16px;">{{ item.product.title }}</p>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p style="font-size: 13px; color: var(--taupe); margin-top: 4px;">{{ item.variant.title }}</p>
                {%- endunless -%}
                <div style="display: flex; align-items: center; gap: 20px; margin-top: 12px;">
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="1"
                    style="width: 60px; padding: 6px; border: 1px solid var(--sand); text-align: center;">
                  <a href="{{ routes.cart_remove_url }}?id={{ item.key }}" style="font-size: 12px; color: var(--taupe);">Remove</a>
                </div>
              </div>
              <div style="text-align: right;">
                <p style="font-family: var(--font-heading);">{{ item.line_price | money }}</p>
              </div>
            </div>
          {%- endfor -%}
          <button type="submit" name="update" class="btn-secondary" style="margin-top: 16px;">Update Cart</button>
        </div>

        <div class="cart-summary-box" style="background: var(--cream); padding: 30px; border-radius: 4px; height: fit-content;">
          <h3 style="font-family: var(--font-heading); font-size: 20px; margin-bottom: 20px;">Order Summary</h3>
          <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <span>Shipping</span>
            <span style="color: var(--sage-green);">Calculated at checkout</span>
          </div>
          <button type="submit" name="checkout" class="btn-primary btn-full">Checkout &rarr;</button>
          <a href="{{ routes.all_products_collection_url }}" class="btn-text btn-full" style="margin-top: 12px; display: block; text-align: center;">Continue Shopping</a>
        </div>
      </div>
    {% endform %}
  {%- else -%}
    <div style="text-align: center; padding: 80px 0;">
      <p style="font-family: var(--font-heading); font-size: 24px; margin-bottom: 16px;">Your cart is empty</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn-primary">Start Shopping &rarr;</a>
    </div>
  {%- endif -%}
</div>
