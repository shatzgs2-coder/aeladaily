<!-- Cart Template - Shopping cart page -->
<div class="cart-page section">
  <div class="container">
    <h1 class="page-title">{{ 'sections.cart.title' | t | default: 'Your Cart' }}</h1>

    {% if cart.item_count > 0 %}
      <div class="cart-layout">
        <!-- Items -->
        <div class="cart-items">
          {% form 'cart', cart %}
            <table class="cart-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Quantity</th>
                  <th>Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                <tr class="cart-item" data-line-key="{{ item.key }}">
                  <td data-label="Product" class="cart-product-cell">
                    <a href="{{ item.url }}" class="cart-item-img-link">
                      {%- if item.image != blank -%}
                        {{ item.image | image_url: width: 120 | image_tag: alt: item.title, loading: 'lazy', class: 'cart-item-img' }}
                      {%- else -%}
                        <div class="cart-item-placeholder"></div>
                      {%- endif -%}
                    </a>
                    <div class="cart-item-info">
                      <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                      {%- unless item.product.has_only_default_variant -%}
                        <p class="cart-variant">{{ item.variant.title }}</p>
                      {%- endunless -%}
                      {%- if item.selling_plan_allocation != blank -%}
                        <p class="cart-selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}
                      {%- if item.discounts.size > 0 -%}
                        {%- for discount in item.discounts -%}
                          <p class="cart-discount">{{ discount.title }} (-{{ discount.amount | money }})</p>
                        {%- endfor -%}
                      {%- endif -%}
                    </div>
                  </td>

                  <td data-label="Quantity" class="cart-qty-cell">
                    <div class="qty-controls cart-qty">
                      <button type="button" class="qty-btn qty-minus" data-action="update-cart-qty" data-line-key="{{ item.key }}" data-new-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease">&minus;</button>
                      <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" pattern="[0-9]*" inputmode="numeric" class="qty-input">
                      <button type="button" class="qty-btn qty-plus" data-action="update-cart-qty" data-line-key="{{ item.key }}" data-new-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase">&plus;</button>
                    </div>
                  </td>

                  <td data-label="Total" class="cart-total-cell">
                    {{ item.final_line_price | money }}
                    {%- if item.original_line_price > item.final_line_price -%}
                      <s class="cart-original-price">{{ item.original_line_price | money }}</s>
                    {%- endif -%}
                  </td>

                  <td class="cart-remove-cell">
                    <button type="button" class="remove-btn" data-action="remove-item" data-line-key="{{ item.key }}" aria-label="Remove {{ item.title }}">
                      &times;
                    </button>
                  </td>
                </tr>
                {%- endfor -%}
              </tbody>
            </table>

            <!-- Continue shopping + Notes -->
            <div class="cart-actions-top">
              <a href="{{ routes.all_products_collection_url }}" class="continue-shopping">Continue Shopping &rarr;</a>
              <label for="cart-note" class="cart-note-label">Add order note:</label>
              <textarea id="cart-note" name="note" rows="2" placeholder="Special instructions for your order..." class="cart-note-input">{{ cart.note }}</textarea>
            </div>

          {% endform %}
        </div>

        <!-- Order Summary Sidebar -->
        <aside class="cart-summary">
          <div class="summary-card">
            <h3>Order Summary</h3>

            <div class="summary-row">
              <span>Subtotal ({{ cart.item_count }} items)</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="summary-row summary-discount">
                  <span>{{ discount.title }}</span>
                  <strong>-{{ discount.total_allocated_amount | money }}</strong>
                </div>
              {%- endfor -%}
            {%- endif -%}

            <div class="summary-divider"></div>

            <div class="summary-row summary-total">
              <span>Total</span>
              <strong>{{ cart.total_price | money_with_currency }}</strong>
            </div>

            {%- if cart.total_discounts > 0 -%}
              <p class="summary-savings">You're saving {{ cart.total_discounts | money }} on this order!</p>
            {%- endif -%}

            <!-- Free shipping progress -->
            <div class="shipping-progress">
              {%- assign free_threshold = 4900 -%}
              {%- assign remaining = free_threshold | minus: cart.total_price -%}
              {%- if remaining <= 0 -%}
                <p>&#9989; You qualify for free EU shipping!</p>
              {%- else -%}
                <p>Add {{ remaining | money }} more for free EU shipping &rarr;</p>
                <progress value="{{ cart.total_price }}" max="{{ free_threshold }}"></progress>
              {%- endif -%}
            </div>

            <form action="/checkout" method="post">
              <button type="submit" name="checkout" class="btn btn--primary btn--lg btn--fullwidth checkout-btn">
                Checkout &mdash; {{ cart.total_price | money }}
              </button>
            </form>
          </div>
        </aside>
      </div>

    {% else %}
      <!-- Empty Cart -->
      <div class="empty-cart">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#CCC" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added any items yet.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--lg">Start Shopping</a>
      </div>
    {% endif %}

  </div>
</div>

<style>
  .page-title { font-family: var(--font-heading, serif); font-size: clamp(28px,4vw,40px); font-weight:500; margin-bottom:32px; }
  .empty-cart { text-align:center; padding:80px 20px; }
  .empty-cart svg { opacity:0.5; margin-bottom:20px; }
  .empty-cart h2 { font-family:var(--font-heading,serif); font-size:26px; color:#999; margin:0 0 10px; }
  .empty-cart p { color:#BBB; margin:0 0 24px; }

  .cart-layout { display:grid; grid-template-columns: 1fr 380px; gap:40px; align-items:start; }

  /* Table */
  .cart-table { width:100%; border-collapse:collapse; }
  .cart-table th { text-align:left; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:#999; padding:12px 0; border-bottom:1px solid var(--color-border); }
  .cart-item td { padding:20px 0; border-bottom:1px solid #F0EBE3; vertical-align:top; }

  .cart-product-cell { display:flex; gap:16px; }
  .cart-item-img-link { display:block; flex-shrink:0; width:90px; height:110px; border-radius:8px; overflow:hidden; background:#EDE8E0; }
  .cart-item-img { width:100%; height:100%; object-fit:cover; }
  .cart-item-placeholder { width:90px; height:110px; background:#EDE8E0; border-radius:8px; }
  .cart-item-info h3 { font-size:15px; font-weight:500; margin:0 0 6px; line-height:1.35; }
  .cart-item-info h3 a { color:var(--color-text); text-decoration:none; }
  .cart-item-info h3 a:hover { color:var(--color-primary); }
  .cart-variant, .cart-selling-plan, .cart-discount { font-size:12px; color:#999; margin:2px 0; }
  .cart-discount { color: #2D8B45; }

  .cart-qty-cell {}
  .cart-qty { display:inline-flex; }
  .cart-original-price { display:block; font-size:13px; color:#AAA; text-decoration:line-through; margin-top:2px; }

  .cart-total-cell { font-weight:600; white-space:nowrap; }

  .remove-btn {
    width:34px; height:34px; border-radius:50%; border:none; background:none;
    cursor:pointer; font-size:22px; color:#CCC; display:inline-flex;align-items:center;justify-content:center;
    transition:all 0.2s;
  }
  .remove-btn:hover { background:rgba(196,92,74,0.08); color:#C45C4A; }

  .cart-actions-top { display:flex; flex-direction:column; gap:16px; margin-top:24px; }
  .continue-shopping { font-size:14px; color:var(--color-primary); text-decoration:none; align-self:flex-start; }
  .cart-note-label { font-size:13px; color:#666; }
  .cart-note-input { width:100%; padding:12px; border:1.5px solid var(--color-border); border-radius:8px; resize:vertical; font-family:inherit; font-size:13px; outline:none; transition:border-color 0.2s;}
  .cart-note-input:focus { border-color:var(--color-primary); }

  /* Summary */
  .summary-card { background:var(--color-bg); border:1px solid var(--color-border); border-radius:16px; padding:28px; position:sticky; top:120px; }
  .summary-card h3 { font-family:var(--font-heading,serif); font-size:20px; font-weight:600; margin:0 0 18px; }
  .summary-row { display:flex; justify-content:space-between; font-size:14px; padding:8px 0; }
  .summary-discount span { color:#2D8B45; }
  .summary-divider { height:1px; background:var(--color-border); margin:8px 0; }
  .summary-total { font-size:17px; }
  .summary-savings { font-size:13px; color:#2D8B45; text-align:center; margin-top:8px; }
  .shipping-progress { margin:20px 0; padding:16px; background:rgba(168,181,160,0.08); border-radius:8px; font-size:13px; }
  .shipping-progress progress { width:100%; margin-top:8px; accent-color:var(--color-accent,#A8B5A0); height:4px; border-radius:2px; }
  .checkout-btn { margin-top:8px; }

  @media(max-width:992px) {
    .cart-layout { grid-template-columns:1fr; }
    .summary-card { position:static; }
  }
</style>
